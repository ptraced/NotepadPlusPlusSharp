<Window x:Class="Caret.Dialogs.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encrypted Backup Manager"
        Width="720" Height="560"
        MinWidth="580" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#2D2D30"
        Foreground="#CCCCCC"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505058"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606068"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#007ACC"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#8B2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#A03030"/>
        </Style>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection -->
        <GroupBox Grid.Row="0" Header="MongoDB Connection" Foreground="#AAAAAA"
                  BorderBrush="#3F3F46" Margin="0,0,0,10" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ConnectionStringBox" Grid.Column="0"
                         Style="{StaticResource DarkTextBox}"
                         Text="mongodb://localhost:27017"
                         Margin="0,0,8,0"/>
                <Button x:Name="TestConnectionButton" Grid.Column="1"
                        Content="Test" Style="{StaticResource DarkButton}"
                        Click="TestConnection_Click"/>
            </Grid>
        </GroupBox>

        <!-- Encryption Password -->
        <GroupBox Grid.Row="1" Header="Encryption Password (AES-256-GCM)" Foreground="#AAAAAA"
                  BorderBrush="#3F3F46" Margin="0,0,0,10" Padding="8">
            <PasswordBox x:Name="PasswordBox" Style="{StaticResource DarkPasswordBox}"/>
        </GroupBox>

        <!-- Backup Current Document -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CurrentDocLabel" Grid.Column="0"
                       Text="No document selected" FontSize="13"
                       Foreground="#808080" VerticalAlignment="Center"/>
            <Button x:Name="BackupButton" Grid.Column="1"
                    Content="Backup Current Document"
                    Style="{StaticResource AccentButton}"
                    Click="Backup_Click"/>
        </Grid>

        <!-- Separator -->
        <Separator Grid.Row="3" Background="#3F3F46" Margin="0,0,0,10"/>

        <!-- Backup List -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Stored Backups" FontSize="14"
                           FontWeight="SemiBold" Foreground="#CCCCCC"/>
                <Button Grid.Column="1" Content="Refresh"
                        Style="{StaticResource DarkButton}" Click="Refresh_Click"
                        Padding="10,4" FontSize="12"/>
            </Grid>

            <ListBox x:Name="BackupsList" Grid.Row="1"
                     Background="#1E1E1E" BorderBrush="#3F3F46"
                     Foreground="#D4D4D4" FontSize="12"
                     SelectionChanged="BackupsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,4,4,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding FileName}" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#D4D4D4"/>
                                <TextBlock Foreground="#808080" FontSize="11">
                                    <Run Text="{Binding BackupDate, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss} UTC'}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding SizeDisplay}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Language}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding OriginalFilePath}" FontSize="10"
                                           Foreground="#606060" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#D4D4D4"/>
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#264F78"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2D2E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RestoreButton" Content="Restore Selected"
                    Style="{StaticResource AccentButton}"
                    Click="Restore_Click" IsEnabled="False" Margin="0,0,8,0"/>
            <Button x:Name="DeleteButton" Content="Delete Selected"
                    Style="{StaticResource DangerButton}"
                    Click="Delete_Click" IsEnabled="False" Margin="0,0,8,0"/>
            <Button Content="Close" Style="{StaticResource DarkButton}"
                    Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
